#!/usr/bin/env python3
import json
import os
import re
import signal
import subprocess
import sys
import time
from dataclasses import asdict, dataclass
from datetime import datetime
from typing import Callable

PID_FILE = f"/run/user/{os.getuid()}/swaystatus.pid"


@dataclass
class Header:
    version: int = 1
    click_events: bool = True
    stop_signal: str = "SIGHUP"
    cont_signal: str = "SIGCONT"


@dataclass
class Block:
    full_text: str
    name: str
    short_text: str = ""
    color: str = ""
    min_width: str = "100%"
    urgent: bool = False
    align: str = "center"
    background: str = ""
    separator: bool = True
    separator_block_width: int = 10
    markup: str = "pango"
    border: str = ""
    border_left: int = 0
    border_right: int = 0
    border_top: int = 0
    border_bottom: int = 0


def stop_handler(*_):
    os.remove(PID_FILE)
    sys.exit(1)


def cont_handler(blocks: list[Callable[[], Block | None]]) -> Callable:
    def f(*_):
        print_blocks(blocks)

    return f


def print_header(header: Header):
    print(json.dumps(asdict(header)))
    print("[", end="")
    sys.stdout.flush()


def print_blocks(blocks: list[Callable[[], Block | None]]):
    block_list = []
    for block in blocks:
        text = block()
        if text is None:
            continue
        block_list.append(asdict(text))
    blocks_json = json.dumps(block_list)
    print(blocks_json, end=",", flush=True)


#
# User defined blocks
#


def datetime_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        now = datetime.now()
        return Block(
            full_text=now.strftime("%m/%d %a %H:%M"),
            name="datetime",
            short_text=now.strftime("%d %H%M"),
        )

    return func


def battery_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        if not os.path.exists("/sys/class/power_supply/BAT0"):
            return None
        with open("/sys/class/power_supply/BAT0/capacity") as file:
            capacity = int(file.read())
        with open("/sys/class/power_supply/BAT0/status") as file:
            status = file.read().strip("\n ")

        icon = "󰁹"
        if capacity < 11:
            icon = "󰁺"
        elif capacity < 21:
            icon = "󰁻"
        elif capacity < 31:
            icon = "󰁼"
        elif capacity < 41:
            icon = "󰁽"
        elif capacity < 51:
            icon = "󰁾"
        elif capacity < 61:
            icon = "󰁿"
        elif capacity < 71:
            icon = "󰂀"
        elif capacity < 81:
            icon = "󰂁"
        elif capacity < 91:
            icon = "󰂂"
        if status.lower() == "charging":
            icon = "󰂄"
        color = ""
        if capacity < 21:
            color = "#ff5555"

        return Block(
            full_text=f"{icon} {capacity}%",
            name="battery",
            short_text=f"B{capacity}",
            color=color,
        )

    return func


def wifi_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        cmd = subprocess.run(
            [
                "/bin/sh",
                "-c",
                "nmcli -g NAME,TYPE connection show --active | grep -F wireless | head -1 | cut -d: -f1",
            ],
            capture_output=True,
        )
        ssid = cmd.stdout.decode().strip("\n ")
        return Block(
            full_text=f"  {ssid}",
            name="wifi",
            short_text=f"W{ssid}",
        )

    return func


def ethernet_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        cmd = subprocess.run(
            [
                "/bin/sh",
                "-c",
                "nmcli -g NAME,TYPE connection show --active | grep -q ethernet",
            ],
        )
        if cmd.returncode != 0:
            return None
        return Block(
            full_text=f"  UP",
            name="ethernet",
            short_text="E",
        )

    return func


def memory_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        cmd = subprocess.run(
            ["/bin/sh", "-c", "free -h | awk '/^Mem:/{ print $3 }'"],
            capture_output=True,
        )
        output = cmd.stdout.decode().strip("\n ")
        return Block(
            full_text=f"󰉉 {output}",
            name="memory",
            short_text=f"M{output}",
        )

    return func


def volume_block() -> Callable[[], Block | None]:
    percent_regex = re.compile(
        r"^.*?\s(?P<percent>[0-9\.]+)(?:\s(?P<muted>\[MUTED\]))?$"
    )

    def func() -> Block | None:
        nonlocal percent_regex
        res = subprocess.run(
            ["wpctl", "get-volume", "@DEFAULT_SINK@"], capture_output=True
        )
        percent_match = percent_regex.search(res.stdout.decode())
        assert percent_match is not None
        percent_str = percent_match.group("percent")
        percent = int(float(percent_str) * 100)
        icon = " "
        if percent_match.group("muted") is not None:
            icon = " "
        return Block(
            full_text=f"{icon} {percent}%",
            name="volume",
            short_text=f"V{percent}",
        )

    return func


def main():
    if len(sys.argv) == 2:
        if sys.argv[1] == "refresh":
            with open(PID_FILE, "r") as file:
                os.kill(int(file.read()), signal.SIGCONT)
            sys.exit(0)

    if os.path.exists(PID_FILE):
        print("swaystatus is already running", file=sys.stderr)
        sys.exit(1)

    with open(PID_FILE, "w") as file:
        file.write(str(os.getpid()))

    header = Header(click_events=False)
    print_header(header)

    blocks: list[Callable[[], Block | None]] = [
        volume_block(),
        wifi_block(),
        ethernet_block(),
        memory_block(),
        battery_block(),
        datetime_block(),
    ]
    signal.signal(signal.SIGCONT, cont_handler(blocks))
    signal.signal(signal.SIGHUP, stop_handler)
    signal.signal(signal.SIGINT, stop_handler)
    signal.signal(signal.SIGTERM, stop_handler)
    while True:
        print_blocks(blocks)
        time.sleep(2)


if __name__ == "__main__":
    try:
        main()
    finally:
        with open(PID_FILE) as file:
            if os.getpid() == int(file.read()):
                stop_handler()
