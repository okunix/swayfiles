#!/usr/bin/env python3
import json
import os
import re
import signal
import subprocess
import sys
import time
from dataclasses import asdict, dataclass
from datetime import datetime
from typing import Callable


@dataclass
class Header:
    version: int = 1
    click_events: bool = True
    stop_signal: str = "SIGHUP"
    cont_signal: str = "SIGCONT"


@dataclass
class Block:
    full_text: str
    name: str
    short_text: str = ""
    color: str = ""
    min_width: str = "100%"
    urgent: bool = False
    align: str = "center"
    background: str = ""
    separator: bool = True
    separator_block_width: int = 10
    markup: str = "pango"
    border: str = ""
    border_left: int = 0
    border_right: int = 0
    border_top: int = 0
    border_bottom: int = 0


def stop_handler(*_):
    sys.exit(1)


def cont_handler(blocks: list[Callable[[], Block | None]]) -> Callable:
    def f(*_):
        print_blocks(blocks)

    return f


def print_header(header: Header):
    os.write(sys.stdout.fileno(), (json.dumps(asdict(header)) + "\n").encode())
    os.write(sys.stdout.fileno(), b"[")
    sys.stdout.flush()


def print_blocks(blocks: list[Callable[[], Block | None]]):
    block_list = []
    for block in blocks:
        text = block()
        if text is not None:
            block_list.append(asdict(text))
    os.write(sys.stdout.fileno(), (json.dumps(block_list) + ",").encode())


#
# User defined blocks
#


def datetime_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        now = datetime.now()
        return Block(
            full_text=now.strftime("%m/%d %a %H:%M"),
            name="datetime",
            short_text=now.strftime("%d %H%M"),
        )

    return func


def battery_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        if not os.path.exists("/sys/class/power_supply/BAT0"):
            return None
        with open("/sys/class/power_supply/BAT0/capacity") as file:
            capacity = int(file.read())
        with open("/sys/class/power_supply/BAT0/status") as file:
            status = file.read().strip()

        icon = "¾░ü╣"
        if capacity < 11:
            icon = "¾░ü║"
        elif capacity < 21:
            icon = "¾░ü╗"
        elif capacity < 31:
            icon = "¾░ü╝"
        elif capacity < 41:
            icon = "¾░üĮ"
        elif capacity < 51:
            icon = "¾░üŠ"
        elif capacity < 61:
            icon = "¾░ü┐"
        elif capacity < 71:
            icon = "¾░éĆ"
        elif capacity < 81:
            icon = "¾░éü"
        elif capacity < 91:
            icon = "¾░éé"
        if status.lower() == "charging":
            icon = "¾░éä"
        color = ""
        if capacity < 21:
            color = "#ff5555"

        return Block(
            full_text=f"{icon} {capacity}%",
            name="battery",
            short_text=f"B{capacity}",
            color=color,
        )

    return func


def wifi_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        cmd = subprocess.run(
            [
                "/bin/sh",
                "-c",
                "nmcli -g NAME,TYPE connection show --active | grep -F wireless | head -1 | cut -d: -f1",
            ],
            capture_output=True,
        )
        if cmd.returncode != 0:
            return None
        ssid = cmd.stdout.decode().strip()
        if ssid.strip() == "":
            return None
        return Block(
            full_text=f"’ć½  {ssid}",
            name="wifi",
            short_text=f"W{ssid}",
        )

    return func


def ethernet_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        cmd = subprocess.run(
            [
                "/bin/sh",
                "-c",
                "nmcli -g NAME,TYPE connection show --active | grep -q ethernet",
            ],
        )
        if cmd.returncode != 0:
            return None
        return Block(
            full_text=f"Ņ╝ē  UP",
            name="ethernet",
            short_text="E",
        )

    return func


def memory_block() -> Callable[[], Block | None]:
    def func() -> Block | None:
        cmd = subprocess.run(
            ["/bin/sh", "-c", "free -h | awk '/^Mem:/{ print $3 }'"],
            capture_output=True,
        )
        if cmd.returncode != 0:
            return None
        output = cmd.stdout.decode().strip()
        return Block(
            full_text=f"¾░ēē {output}",
            name="memory",
            short_text=f"M{output}",
        )

    return func


def volume_block() -> Callable[[], Block | None]:
    percent_regex = re.compile(
        r"^.*?\s(?P<percent>[0-9\.]+)(?:\s(?P<muted>\[MUTED\]))?$"
    )

    def func() -> Block | None:
        nonlocal percent_regex
        cmd = subprocess.run(
            ["wpctl", "get-volume", "@DEFAULT_SINK@"], capture_output=True
        )
        if cmd.returncode != 0:
            return None
        percent_match = percent_regex.search(cmd.stdout.decode())
        assert percent_match is not None
        percent_str = percent_match.group("percent")
        percent = int(float(percent_str) * 100)
        icon = "’Ć© "
        if percent_match.group("muted") is not None:
            icon = "Ņ╗© "
        return Block(
            full_text=f"{icon} {percent}%",
            name="volume",
            short_text=f"V{percent}",
        )

    return func


def mpd_block() -> Callable[[], Block | None]:
    paused_regex = re.compile(r"^\[paused\]")

    def func() -> Block | None:
        cmd = subprocess.run(["/bin/sh", "-c", "mpc"], capture_output=True)
        if cmd.returncode != 0:
            return None
        lines = cmd.stdout.decode().splitlines()
        if paused_regex.match(lines[1]):
            return None
        song = lines[0]
        if len(song) > 30:
            song = song[:27] + "..."
        return Block(
            full_text=f"¾░Äć {song}",
            name="mpd",
            short_text=f"{song}",
        )

    return func


def main():
    header = Header(click_events=False)
    print_header(header)

    blocks: list[Callable[[], Block | None]] = [
        # mpd_block(),
        volume_block(),
        wifi_block(),
        ethernet_block(),
        memory_block(),
        battery_block(),
        datetime_block(),
    ]
    signal.signal(signal.SIGCONT, cont_handler(blocks))
    signal.signal(signal.SIGHUP, stop_handler)
    signal.signal(signal.SIGINT, stop_handler)
    signal.signal(signal.SIGTERM, stop_handler)
    while True:
        print_blocks(blocks)
        time.sleep(2)


if __name__ == "__main__":
    main()
